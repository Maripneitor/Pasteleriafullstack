<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: Arial, sans-serif; color: #333; margin: 40px; }
        .header { text-align: center; border-bottom: 2px solid <%= config.primaryColor || '#e91e63' %>; padding-bottom: 10px; }
        .title { font-size: 24px; color: <%= config.primaryColor || '#e91e63' %>; }
        .meta { display: flex; justify-content: space-between; margin: 20px 0; font-size: 12px; color: #666; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th { background-color: <%= config.primaryColor || '#e91e63' %>; color: white; padding: 10px; text-align: left; }
        td { border-bottom: 1px solid #ddd; padding: 10px; }
        .footer { margin-top: 50px; font-size: 10px; text-align: center; color: #999; }
    </style>
</head>
<body>
    <div class="header">
        <div class="title"><%= title %></div>
        <div><%= config.logo %></div>
    </div>
    
    <div class="meta">
        <div>Fecha: <%= date %></div>
        <div>Generado por: <%= user %></div>
    </div>

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Producto</th>
                <th>Monto</th>
            </tr>
        </thead>
        <tbody>
            <% items.forEach(item => { %>
                <tr>
                    <td><%= item.id %></td>
                    <td><%= item.product %></td>
                    <td><%= item.amount %></td>
                </tr>
            <% }); %>
        </tbody>
    </table>

    <div class="footer">
        Este documento es una representación digital generada con Puppeteer.
    </div>
</body>
</html>
